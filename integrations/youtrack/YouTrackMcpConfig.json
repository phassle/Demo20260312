{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "_comment": "MCP server configuration for YouTrack integration. Day 2: we build this as a real MCP server.",
  "mcpServers": {
    "youtrack": {
      "command": "dotnet",
      "args": ["run", "--project", "integrations/youtrack/YouTrackMcp.csproj"],
      "env": {
        "YOUTRACK_URL": "https://youtrack.trapets.se",
        "YOUTRACK_TOKEN": "${YOUTRACK_TOKEN}"
      }
    }
  }
}
